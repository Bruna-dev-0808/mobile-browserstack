{
  "name": "clean-mobile-browserstack",
  "version": "1.0.0",
  "description": "Automacao mobile com WebdriverIO, Appium, BrowserStack, Cucumber, Chai e Allure para o WDIO Demo App.",
  "private": true,
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "test:android": "cross-env PLATFORM=android wdio run ./wdio.conf.js",
    "test:ios": "cross-env PLATFORM=ios wdio run ./wdio.conf.js",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.20.0",
    "@wdio/appium-service": "^9.20.0",
    "@wdio/browserstack-service": "^9.20.0",
    "@wdio/cli": "^9.20.0",
    "@wdio/cucumber-framework": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "allure-commandline": "^2.34.1",
    "appium": "^2.19.0",
    "chai": "^5.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7"
  }
}
